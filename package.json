{
  "name": "@origozero/zeromind",
  "version": "0.6.0",
  "description": "ZeroMind IDE plugin \u2014 MCP server with first-class support for every MCP client (Claude Code, Cursor, Codex, Gemini CLI, OpenCode, Cline, Continue, Windsurf, Zed, \u2026)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zeromind": "dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "templates/",
    "dist-publishing/",
    "docs/install-matrix.json",
    "docs/install-matrix.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tools tests --ext .ts --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.ts\" \"tools/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "jsonc-parser": "^3.3.1",
    "undici": "^6.0.0",
    "ws": "^8.16.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OrigoZero/zeromind-plugin.git"
  },
  "license": "MIT",
  "keywords": [
    "zeromind",
    "mcp",
    "claude-code",
    "cursor",
    "codex",
    "gemini-cli",
    "opencode",
    "cline",
    "continue",
    "windsurf",
    "zed",
    "origozero",
    "zero-engine"
  ]
}
