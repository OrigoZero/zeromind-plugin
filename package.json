{
  "name": "@origozero/zeromind",
  "version": "0.2.0",
  "description": "ZeroMind IDE plugin — MCP server for Claude Code, Cursor, and Codex",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zeromind": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tools tests --ext .ts --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.ts\" \"tools/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "undici": "^6.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OrigoZero/zeromind-plugin.git"
  },
  "license": "MIT",
  "keywords": [
    "zeromind",
    "mcp",
    "claude-code",
    "cursor",
    "codex",
    "origozero",
    "zero-engine"
  ]
}
